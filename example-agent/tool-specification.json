{
  "name": "sample-documentation-agent",
  "namespace": "documentation",
  "version": "1.0.0",
  "description": "Documentation assistance agent using Claude 3.5 Sonnet for {{tenant.id}}",
  "interface": "HTTP",
  "endpoint": "https://documentation-agent-{{tenant.id}}.example.com/api",
  "provider_id": "aws-bedrock-claude",
  "tools": [
    {
      "name": "agent_start",
      "description": "Start a new Bedrock Agent session",
      "input_schema": {
        "type": "object",
        "properties": {
          "session_id": {
            "type": "string",
            "description": "Optional custom session ID"
          },
          "context": {
            "type": "object",
            "description": "Additional context for the session"
          },
          "headers": {
            "type": "object",
            "description": "Headers from mcp-orch (X-Subject-Id, X-Tenant-Id, etc.)",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "session_id": {
            "type": "string",
            "description": "Session identifier"
          },
          "status": {
            "type": "string",
            "description": "Status of agent start"
          },
          "message": {
            "type": "string",
            "description": "Initial response from the agent"
          }
        },
        "required": ["session_id", "status", "message"]
      }
    },
    {
      "name": "agent_send",
      "description": "Send a message to the Bedrock Agent",
      "input_schema": {
        "type": "object",
        "properties": {
          "session_id": {
            "type": "string",
            "description": "Session identifier"
          },
          "message": {
            "type": "string",
            "description": "User message to send to the agent"
          },
          "headers": {
            "type": "object",
            "description": "Headers from mcp-orch (X-Subject-Id, X-Tenant-Id, etc.)",
            "additionalProperties": {
              "type": "string"
            }
          }
        },
        "required": ["session_id", "message"]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "session_id": {
            "type": "string",
            "description": "Session identifier"
          },
          "response": {
            "type": "string",
            "description": "Agent's response"
          },
          "status": {
            "type": "string",
            "description": "Status of the message processing"
          },
          "citations": {
            "type": "array",
            "description": "Knowledge base citations",
            "items": {"type": "object"}
          }
        },
        "required": ["session_id", "response", "status"]
      }
    },
    {
      "name": "agent_finalize",
      "description": "Finalize an agent session and provide a summary",
      "input_schema": {
        "type": "object",
        "properties": {
          "session_id": {
            "type": "string",
            "description": "Session identifier to finalize"
          },
          "headers": {
            "type": "object",
            "description": "Headers from mcp-orch (X-Subject-Id, X-Tenant-Id, etc.)",
            "additionalProperties": {
              "type": "string"
            }
          }
        },
        "required": ["session_id"]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "session_id": {
            "type": "string",
            "description": "Finalized session identifier"
          },
          "status": {
            "type": "string",
            "description": "Status of session finalization"
          },
          "summary": {
            "type": "string",
            "description": "Summary of the session"
          }
        },
        "required": ["session_id", "status"]
      }
    },
    {
      "name": "get_session_info",
      "description": "Get information about a specific session",
      "input_schema": {
        "type": "object",
        "properties": {
          "session_id": {
            "type": "string",
            "description": "ID of the session to get info for"
          }
        },
        "required": ["session_id"]
      },
      "output_schema": {
        "type": "object",
        "description": "Session information object"
      }
    },
    {
      "name": "list_sessions",
      "description": "List all active sessions",
      "input_schema": {
        "type": "object",
        "properties": {}
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "sessions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "session_id": {"type": "string"},
                "created_at": {"type": "string"},
                "status": {"type": "string"},
                "user_id": {"type": "string"}
              }
            }
          },
          "total": {"type": "integer"}
        }
      }
    },
    {
      "name": "get_agent_info",
      "description": "Get Bedrock Agent configuration information",
      "input_schema": {
        "type": "object",
        "properties": {}
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "agent_id": {"type": "string"},
          "agent_alias_id": {"type": "string"},
          "knowledge_base_id": {"type": "string"},
          "region": {"type": "string"},
          "status": {"type": "string"}
        }
      }
    }
  ],
  "access_control_policy": {
    "language": "rego",
    "policy": "package tool.documentation\n\nallow_access {\n    input.headers[\"X-Tenant-Id\"] == \"tenant-123\"\n    input.headers[\"X-Authentication-Session-Scope\"] in [\"admin\", \"user\"]\n}\n\nallow_access {\n    input.headers[\"X-Tenant-Id\"] == \"tenant-456\"\n    input.headers[\"X-Subject-Id\"] in [\"doc-writer-1\", \"doc-writer-2\"]\n}"
  },
  "discovery_policy": {
    "language": "rego",
    "policy": "package tool.documentation.discovery\n\nallow_discovery {\n    input.headers[\"X-Tenant-Id\"] == \"tenant-123\"\n}\n\nallow_discovery {\n    input.headers[\"X-Tenant-Id\"] == \"tenant-456\"\n    input.headers[\"X-Authentication-Session-Scope\"] in [\"admin\", \"user\"]\n}"
  },
  "templates": {
    "endpoint": "https://documentation-agent-{{tenant.id}}.example.com/api",
    "headers": {
      "X-Tenant-Context": "{{tenant.id}}",
      "X-User-Context": "{{subject.id}}",
      "X-Client-Context": "{{client.id}}"
    }
  }
}
